{
  "name": "@leesuyeon/ssr-devtools",
  "version": "0.1.8",
  "description": "Chrome DevTools companion for inspecting Next.js SSR fetch calls",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leeyounagh/ssr-devtools.git",
    "directory": "packages/server"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./instrumentation": {
      "types": "./dist/instrumentation.d.ts",
      "import": "./dist/instrumentation.js",
      "require": "./dist/instrumentation.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./route": {
      "types": "./dist/route.d.ts",
      "import": "./dist/route.js",
      "require": "./dist/route.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "next": ">=13.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
